var output = [];
var count = 1;

 function fizzbuzz(){

    if (count%3 === 0 ){
        output.push("Fizz")
        count++
    }
    if (count%5 == 0 ){
        output.push("Buzz")
        count++
    }
    if (count%5 && count%3){
        output.push("FizzBuzz")
        count++
    }else {
    output.push(count);
    count++};

        console.log(output)
 }